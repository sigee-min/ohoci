OHOCI_ENV=local
OHOCI_HTTP_ADDRESS=:8080
OHOCI_PUBLIC_BASE_URL=http://localhost:8080
OHOCI_PUBLIC_HOSTNAME=localhost
OHOCI_TRUSTED_PROXY_CIDRS=0.0.0.0/0
OHOCI_ADMIN_ALLOW_CIDRS=0.0.0.0/0
OHOCI_WEBHOOK_ALLOW_CIDRS=0.0.0.0/0
OHOCI_UI_DIR=./web/dist
OHOCI_SESSION_COOKIE_NAME=ohoci_session
OHOCI_SESSION_SECRET=replace-me
OHOCI_SESSION_SECRET_FILE=
OHOCI_DATA_ENCRYPTION_KEY=
OHOCI_DATA_ENCRYPTION_KEY_FILE=
OHOCI_SESSION_TTL=12h
OHOCI_AUTH_LOCKOUT_ATTEMPTS=15
OHOCI_AUTH_LOCKOUT_DURATION=5m
OHOCI_CLEANUP_INTERVAL=1m

# UI assets:
# - local development defaults to ./web/dist
# - build them with: cd web && npm install && npm run build
# - container images can override OHOCI_UI_DIR to the packaged asset path
# - trusted proxies gate whether forwarded headers are accepted
# - admin/UI and webhook access use separate CIDR allowlists
# - warning: with OHOCI_TRUSTED_PROXY_CIDRS=0.0.0.0/0, direct clients can spoof X-Forwarded-For
# - narrow trusted proxies to your real reverse proxy / load balancer CIDRs before relying on the allowlists

# Database default:
# - SQLite is the default for local development and single-node production.
# - Keep the DB on a local persistent disk for the node or container.
# - Example single-node container path: /var/lib/ohoci/data/ohoci.db
# - For repo-local dev, ./ohoci.local.db also works.
# - Leave OHOCI_DATABASE_URL empty unless you are opting into MySQL for scaled/HA deployment.
OHOCI_DATABASE_URL=
OHOCI_SQLITE_PATH=./ohoci.local.db

# GitHub App bootstrap defaults:
# - first-login Setup is the primary path for saving the active GitHub App and repository allowlist
# - save a staged App in Setup only when rotating credentials or replacing the active installation
# - staged and active App configs must use different webhook secrets before promotion
# - if Setup saves an app config without a webhook secret, the server generates and stores one automatically
# - these env values are optional bootstrap defaults for the active GitHub App only
# - selected repositories must also be visible to the installation you configure
OHOCI_GITHUB_API_BASE_URL=https://api.github.com
OHOCI_GITHUB_APP_ID=
OHOCI_GITHUB_INSTALLATION_ID=
OHOCI_GITHUB_APP_PRIVATE_KEY=
OHOCI_GITHUB_APP_PRIVATE_KEY_FILE=
OHOCI_GITHUB_WEBHOOK_SECRET=replace-me
OHOCI_GITHUB_WEBHOOK_SECRET_FILE=
OHOCI_GITHUB_ALLOWED_REPOS=example/repo-one,example/repo-two

# Default OCI env auth can be fake or instance principal.
# The CMS can additionally store an encrypted OCI API-key credential in the DB
# and the backend will prefer that credential at runtime when it exists.
# These OCI target values now act as bootstrap defaults and can be overridden
# later from the admin CMS without restarting the service.
OHOCI_OCI_AUTH_MODE=fake
OHOCI_OCI_COMPARTMENT_OCID=
OHOCI_OCI_AVAILABILITY_DOMAIN=
OHOCI_OCI_SUBNET_OCID=
OHOCI_OCI_NSG_OCIDS=
OHOCI_OCI_IMAGE_OCID=
OHOCI_OCI_ASSIGN_PUBLIC_IP=false

OHOCI_RUNNER_DOWNLOAD_BASE_URL=https://github.com/actions/runner/releases/download
OHOCI_RUNNER_VERSION=2.325.0
OHOCI_RUNNER_USER=runner
OHOCI_RUNNER_WORKDIR=/home/runner/actions-runner
